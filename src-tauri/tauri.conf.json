{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "i18n Manager",
  "version": "0.1.0",
  "identifier": "com.jiayiqiu.webcode-i18n-manager",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "i18n 检查工具",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
